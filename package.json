{
  "name": "@venturet/openclaw-task-manager",
  "version": "1.0.4",
  "description": "OpenClaw Task Manager Plugin - Automated task management with Cron Jobs and thinking notes",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "openclaw-task": "dist/cli/task.js"
  },
  "scripts": {
    "build": "tsc",
    "prepublish": "npm run build",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "automation",
    "cron",
    "task-manager"
  ],
  "license": "MIT",
  "openclaw": {
    "plugins": {
      "install": {
        "type": "npm"
      }
    },
    "extensions": {
      "./dist/index.js": {}
    }
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "uuid": "^9.0.0"
  }
}
