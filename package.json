{
  "name": "@venturet/openclaw-task-manager",
  "version": "1.1.0",
  "description": "OpenClaw Task Manager Plugin - Automated task management with Cron Jobs and thinking notes",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "openclaw-task": "dist/cli/task.js"
  },
  "scripts": {
    "build": "tsc && cp -r src/templates dist/templates",
    "prepublish": "npm run build",
    "clean": "rm -rf dist",
    "test": "node dist/cli/task.js list",
    "test:full": "node dist/cli/task.js stats && node dist/cli/task.js list",
    "lint": "prettier --check \"src/**/*.ts\" \"*.json\" \"*.md\" || true",
    "format": "prettier --write \"src/**/*.ts\" \"*.json\" \"*.md\"",
    "version:bump": "npm version",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "postinstall": "npm run test:full"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "automation",
    "cron",
    "task-manager"
  ],
  "license": "MIT",
  "openclaw": {
    "plugins": {
      "install": {
        "type": "npm"
      }
    },
    "extensions": {
      "./dist/index.js": {}
    }
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "uuid": "^9.0.0"
  }
}
