{
  "template": "daily-brief",
  "description": "Daily briefing for specific topics",
  "defaultSchedule": "0 */4 * * *",
  "defaultAgent": "main",
  "phases": ["monitoring", "analyzing", "alerting"],
  "rules": {
    "maxConsecutiveFailures": 3,
    "compactThreshold": 15000,
    "retentionRounds": 3
  }
}
